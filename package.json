{
  "name": "histora",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "author": "Jet",
  "description": "Local GUI and sync agent for AI conversation sessions.",
  "main": "src/desktop-main.mjs",
  "bin": {
    "histora": "./src/cli.mjs",
    "chathub": "./src/cli.mjs"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "serve": "node src/server.mjs",
    "desktop": "electron .",
    "sync": "node src/cli.mjs sync",
    "status": "node src/cli.mjs status",
    "doctor": "node src/cli.mjs doctor",
    "install-launchd": "node src/cli.mjs install-launchd",
    "test": "node src/test.mjs",
    "pack:mac": "electron-builder --mac dir",
    "pack:win": "electron-builder --win dir --x64",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --x64"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.jet.histora",
    "productName": "Histora",
    "files": [
      "package.json",
      "src/**/*",
      "public/**/*",
      "build/**/*",
      "README.md",
      "histora.config.yaml"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "newtol-labs",
        "repo": "histora"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "Histora 需要访问文档文件夹以同步 Codex 和 Claude Code 的对话记录。 / Histora needs access to the Documents folder to sync conversation logs from Codex and Claude Code.",
        "NSDownloadsFolderUsageDescription": "Histora 需要访问下载文件夹以读取导出的会话文件。 / Histora needs access to the Downloads folder to read exported session files.",
        "NSDesktopFolderUsageDescription": "Histora 需要访问桌面文件夹以读取项目相关的会话。 / Histora needs access to the Desktop folder to read project-related sessions.",
        "NSHomeKitUsageDescription": "Histora 需要访问用户根目录下的隐藏配置文件以识别 AI 代理设置。 / Histora needs access to hidden configuration files in the user home directory to identify AI agent settings."
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 120,
      "iconTextSize": 14,
      "contents": [
        {
          "x": 135,
          "y": 210,
          "type": "file"
        },
        {
          "x": 405,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "sign": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
